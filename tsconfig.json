{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@/config": ["src/config/*"],
      "@/types": ["src/types/*"],
      "@/utils": ["src/utils/*"],
      "@/services": ["src/services/*"],
      "@/store": ["src/store/*"],
      "@/theme": ["src/theme/*"],
      "@/hooks": ["src/hooks/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
